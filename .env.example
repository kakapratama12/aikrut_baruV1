# =============================================================
# Aikrut Environment Variables
# =============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================

# --- MongoDB ---
DB_NAME=aikrut

# --- Backend Secrets ---
# IMPORTANT: Change these in production!
SUPER_ADMIN_PASSWORD=changeme123
JWT_SECRET=aikrut-secret-key-2024
ADMIN_JWT_SECRET=aikrut-admin-secret-key-2024

# --- CORS ---
# Comma-separated list of allowed origins
# For local dev, use * or specify your frontend URL
# For production, set to your domain: https://yourdomain.com
CORS_ORIGINS=*

# --- Frontend (build-time) ---
# The URL the browser uses to reach the backend API.
# Local dev via docker compose: http://localhost:8000
# Production with domain: https://yourdomain.com
REACT_APP_BACKEND_URL=http://localhost:8000

# --- App Port ---
# The port Nginx listens on (maps to container port 80)
APP_PORT=3000

# --- Production Domain (only needed for docker-compose.prod.yml) ---
# DOMAIN=yourdomain.com
# SSL_EMAIL=admin@yourdomain.com
